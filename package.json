{
  "name": "startgg-overlay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "start": "node server.js",
    "electron:dev": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "main": "main.js",
  "dependencies": {
    "axios": "^1.4.0",
    "express": "^4.18.2",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.4.7",
    "vite": "^5.1.0"
  },
  "build": {
    "appId": "com.example.startgg-overlay",
    "productName": "StartGG Overlay",
    "mac": {
      "target": ["dmg", "zip"]
    },
    "files": [
      "dist/**/*",
      "main.js",
      "server.js",
      "package.json"
    ],
    "directories": {
      "output": "dist_electron"
    }
  }
}
